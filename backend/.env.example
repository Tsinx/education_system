APP_NAME=教育智能体平台 API
APP_VERSION=0.1.0
LLM_PROVIDER=dashscope
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://chat.cqjtu.edu.cn/ds/api/v1
DEEPSEEK_MODEL=deepseek-chat
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus
BIGMODEL_MCP_API_KEY=
BIGMODEL_MCP_SEARCH_URL=https://open.bigmodel.cn/api/mcp/web_search_prime/mcp
BIGMODEL_MCP_READER_URL=https://open.bigmodel.cn/api/mcp/web_reader/mcp
BIGMODEL_MCP_TIMEOUT_S=60
RAG_EMBEDDING_PROVIDER=local
RAG_RERANK_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-m3
LOCAL_RERANK_MODEL=BAAI/bge-reranker-v2-m3
LOCAL_INFERENCE_DEVICE=auto
LOCAL_EMBEDDING_BATCH_SIZE=32
LOCAL_RERANK_BATCH_SIZE=16
LOCAL_RERANK_MAX_LENGTH=512
LOCAL_USE_FP16=true
LOCAL_RAG_FALLBACK_REMOTE=false
RAG_RETRIEVAL_PROVIDER=local_sqlite
RAG_TOP_K=20
RAG_RERANK_TOP_K=8
RAG_MIN_SCORE=0.2
ENABLE_MATERIAL_CHUNK_PIPELINE=false
ENABLE_CHUNK_RETRIEVAL=false
KNOWLEDGE_EXTRACT_MAX_SECTIONS=4
KNOWLEDGE_EXTRACT_SECTION_TIMEOUT_S=240
KNOWLEDGE_EXTRACT_ENABLE_SUPPLEMENT=false
KNOWLEDGE_GRAPH_REFINE_BATCH_SIZE=10
KNOWLEDGE_GRAPH_REFINE_CANDIDATE_K=16
